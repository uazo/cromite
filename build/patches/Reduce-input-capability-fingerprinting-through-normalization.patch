@@ -48,6 +49,7 @@ PointerDevice ToPointerDevice(const POINTER_DEVICE_INFO& device) {
 }  // namespace
 
 std::pair<int, int> GetAvailablePointerAndHoverTypesImpl() {
+  if ((true)) return {POINTER_TYPE_FINE, HOVER_TYPE_HOVER};
