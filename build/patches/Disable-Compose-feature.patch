       "//chrome/browser/glic",
@@ -232,7 +232,7 @@ static_library("test_support") {
       "render_view_context_menu_test_util.cc",
     ]
     public_deps += [ "//extensions/buildflags" ]
-    deps += [ "//chrome/browser/compose" ]
