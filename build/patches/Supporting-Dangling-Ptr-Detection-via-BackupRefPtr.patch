+  // observer can exist in an ObserverList so long as nothing iterates over
+  // the ObserverList before the list itself is destroyed.
+  // if(IsInObserverList()) {
+  //   LOG(INFO) << "--- ~CheckedObserver " << base::debug::StackTrace();
+  // }
 
