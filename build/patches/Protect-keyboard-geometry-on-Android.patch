+    // Receives IME animation lifecycle events and keeps the protected transition state aligned.
+    private final WindowInsetsAnimationListener mInsetsAnimationListener =
+            new WindowInsetsAnimationListener() {
+                @Override
+                public void onPrepare(WindowInsetsAnimationCompat animation) {
+                    if (!isImeAnimation(animation)) return;
+                    boolean keyboardWasVisible =
+                            isProtectedKeyboardResizeWithoutEditableTopControls(getKeyboardInset());
+                    mImeClosing = keyboardWasVisible;
+                    if (!keyboardWasVisible
+                            && !mControlsState.mEditableTopControlsActive
+                            && !mControlsState.mEarlyShowCaptured) {
+                        captureCurrentBrowserControlsState(getViewportWidth());
+                    }
