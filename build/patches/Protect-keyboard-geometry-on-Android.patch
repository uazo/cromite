+    /** Applies cc's cumulative unused vertical delta to the remaining physical range. */
+    public void pullCompositorOverscroll(float accumulatedDeltaY) {
+        int oldScrollY = getScrollY();
+        int targetScrollY = Math.max(0, Math.min(
+                mCompositorHandoff.mPullStartY + Math.round(accumulatedDeltaY),
+                getMaximumScrollY()));
+        if (targetScrollY != oldScrollY) {
+            mPanState.mUnlockedPhysicalPanY =
+                    Math.max(mPanState.mUnlockedPhysicalPanY, targetScrollY);
+            scrollTo(0, targetScrollY);
+        }
+        if (DEBUG_DIAGNOSTICS) {
+            Log.i(TAG,
+                    "--pullCompositorOverscroll accumulatedDeltaY=%.2f start=%d old=%d"
+                            + " target=%d actual=%d max=%d",
+                    accumulatedDeltaY, mCompositorHandoff.mPullStartY, oldScrollY,
+                    targetScrollY, getScrollY(), getMaximumScrollY());
+        }
+    }
