+    private @Nullable ProtectedViewportScrollView findProtectedViewport() {
+        View current = mTab.getContentView();
+        while (current != null) {
+            if (current instanceof ProtectedViewportScrollView protectedViewport) {
+                return protectedViewport;
+            }
+            ViewParent parent = current.getParent();
+            current = parent instanceof View ? (View) parent : null;
+        }
+        return null;
+    }
