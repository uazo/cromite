+     */
+    private void applyRequestedPan() {
+        if (!mPanState.hasRequest() || getHeight() == 0) {
+            if (DEBUG_DIAGNOSTICS) {
+                Log.i(
+                                TAG,
+                                "--applyRequestedPan (exit1) rect=%s height=%d contentHeight=%d",
+                                mPanState.mRequestedRect,
+                                getHeight(),
+                                mContent.getHeight());
+            }
+            return;
+        }
