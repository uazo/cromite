+                        mLastGestureX,
+                        contentY,
+                        unconsumedY);
+                mCompositorHandoff.mScrollInProgress = true;
+                if (DEBUG_DIAGNOSTICS) {
+                    Log.i(
+                            TAG,
+                            "--ccScrollBegin time=%d point=%.1f,%.1f deltaY=%d",
+                            mLastGestureEventTimeMs,
+                            mLastGestureX,
+                            contentY,
+                            unconsumedY);
+                }
+            }
