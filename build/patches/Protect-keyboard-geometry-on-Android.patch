+    /**
+     * Captures the last unforced top-controls state before Chromium applies a controls layout.
+     *
+     * <p>A forced show for an editable element must not change the geometry exposed to Blink.
+     */
+    public void onControlsOffsetChangedBeforeLayout(int topOffset, boolean isVisibilityForced) {
+        if (!mEnabled) return;
+        if (!isVisibilityForced && mBrowserControlsStateProvider != null) {
+            mControlsState.mLastUnforcedResizeView =
+                    BrowserControlsUtils.controlsResizeView(mBrowserControlsStateProvider);
+            mControlsState.mLastUnforcedTopOffset =
+                    Math.round(mBrowserControlsStateProvider.getTopVisibleContentOffset());
+        }
+        updateEditableTopControlsState(isVisibilityForced);
+        updateShownTopControlsHeight();
+        if (DEBUG_DIAGNOSTICS) {
+            logBrowserControlsState("before-layout", topOffset, isVisibilityForced);
+        }
+    }
