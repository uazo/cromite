+        super.onSizeChanged(w, h, oldw, oldh);
+
+        if (DEBUG_DIAGNOSTICS) {
+            Log.i(
+                    TAG,
+                    "--onSizeChanged size=%dx%d oldSize=%dx%d top=%d contentHeight=%d"
+                            + " scrollY=%d requestedRect=%s",
+                    w,
+                    h,
+                    oldw,
+                    oldh,
+                    getTop(),
+                    mContent.getHeight(),
+                    getScrollY(),
+                    mPanState.mRequestedRect);
+        }
