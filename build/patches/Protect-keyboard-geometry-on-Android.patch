+        if (isTouchEvent && getMaximumScrollY() > 0 && unconsumedY != 0) {
+            mCompositorHandoff.mCurrentGestureForwardedDelta = true;
+            if (DEBUG_DIAGNOSTICS) {
+                Log.i(
+                        TAG,
+                        "--overscrollHandoff scrollY=%d range=%d physicalLimit=%d"
+                                + " deltaY=%d consumedY=%d unconsumedY=%d",
+                        scrollY,
+                        scrollRangeY,
+                        physicalPanLimitY,
+                        deltaY,
+                        consumedY,
+                        unconsumedY);
+            }
