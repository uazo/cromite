+    /** Intercepts only gestures assigned to the vertical protected-viewport axis. */
+    @Override
+    public boolean onInterceptTouchEvent(MotionEvent event) {
+        if (!mEnabled) return false;
+        updateGestureRoutingState(event);
+        if (mGestureRoutingState == GestureRoutingState.HORIZONTAL) {
+            if (DEBUG_DIAGNOSTICS) {
+                Log.i(TAG, "--skipProtectedIntercept horizontal gesture");
+            }
+            return false;
+        }
+        return super.onInterceptTouchEvent(event);
+    }
